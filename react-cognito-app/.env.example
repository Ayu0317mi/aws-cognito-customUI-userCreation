VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# OAuth Configuration for Google SSO
# Format: https://your-domain-prefix.auth.{region}.amazoncognito.com
VITE_COGNITO_DOMAIN=your-domain-prefix.auth.xxxxxx.amazoncognito.com

# Redirect URLs (comma-separated for multiple environments)
VITE_REDIRECT_SIGN_IN=https://your-production-domain.com/
VITE_REDIRECT_SIGN_OUT=https://your-production-domain.com/
